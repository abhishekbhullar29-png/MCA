#include <iostream>
#include <fstream>
#include <vector>
using namespace std;

struct Expense
{
    string date;
    string category;
    string description;
    float amount;
};

vector<Expense> expenses;

// Save data to file
void saveToFile()
{
    ofstream file("expenses.txt");

    for (Expense e : expenses)
    {
        file << e.date << endl;
        file << e.category << endl;
        file << e.description << endl;
        file << e.amount << endl;
    }

    file.close();
}

// Load data from file
void loadFromFile()
{
    ifstream file("expenses.txt");

    Expense e;

    while (getline(file, e.date))
    {
        getline(file, e.category);
        getline(file, e.description);
        file >> e.amount;
        file.ignore();

        expenses.push_back(e);
    }

    file.close();
}

// Add Expense
void addExpense()
{
    Expense e;

    cout << "\nEnter Date (DD/MM/YYYY): ";
    cin >> e.date;

    cout << "Enter Category: ";
    cin >> e.category;

    cin.ignore();

    cout << "Enter Description: ";
    getline(cin, e.description);

    cout << "Enter Amount: ";
    cin >> e.amount;

    expenses.push_back(e);

    saveToFile();

    cout << "\nExpense Added Successfully!\n";
}

// View All Expenses
void viewExpenses()
{
    if (expenses.empty())
    {
        cout << "\nNo Expense Found!\n";
        return;
    }

    cout << "\n========== Expense List ==========\n";

    for (int i = 0; i < expenses.size(); i++)
    {
        cout << "\nExpense " << i + 1 << endl;
        cout << "Date        : " << expenses[i].date << endl;
        cout << "Category    : " << expenses[i].category << endl;
        cout << "Description : " << expenses[i].description << endl;
        cout << "Amount      : Rs. " << expenses[i].amount << endl;
    }
}

// Search Expense by Category
void searchCategory()
{
    string cat;
    bool found = false;

    cout << "\nEnter Category: ";
    cin >> cat;

    cout << "\nMatching Expenses\n";

    for (Expense e : expenses)
    {
        if (e.category == cat)
        {
            found = true;

            cout << "\nDate        : " << e.date << endl;
            cout << "Category    : " << e.category << endl;
            cout << "Description : " << e.description << endl;
            cout << "Amount      : Rs. " << e.amount << endl;
        }
    }

    if (!found)
    {
        cout << "\nNo Expense Found!\n";
    }
}

// Calculate Total Expense
void totalExpense()
{
    float total = 0;

    for (Expense e : expenses)
    {
        total += e.amount;
    }

    cout << "\nTotal Expense = Rs. " << total << endl;
}

