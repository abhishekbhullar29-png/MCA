import tkinter as tk
from tkinter import messagebox

def knapsack(stocks, budget):
    n = len(stocks)
    dp = [[0]*(budget+1) for _ in range(n+1)]

    for i in range(1, n+1):
        name, price, profit = stocks[i-1]

        for w in range(budget+1):
            if price <= w:
                dp[i][w] = max(dp[i-1][w], profit + dp[i-1][w-price])
            else:
                dp[i][w] = dp[i-1][w]

    return dp[n][budget]


def fractional(stocks, budget):
    stocks = sorted(stocks, key=lambda x: x[2]/x[1], reverse=True)
    profit = 0

    for name, price, p in stocks:
        if budget >= price:
            budget -= price
            profit += p
        else:
            profit += p * (budget/price)
            break

    return profit

stocks = []

def add_stock():
    name = entry_name.get()
    price = entry_price.get()
    profit = entry_profit.get()

    if name == "" or price == "" or profit == "":
        messagebox.showerror("Error", "Fill all fields")
        return

    stocks.append((name, int(price), int(profit)))
    listbox.insert(tk.END, f"{name} | Price:{price} | Profit:{profit}")

    entry_name.delete(0, tk.END)
    entry_price.delete(0, tk.END)
    entry_profit.delete(0, tk.END)


def calculate():
    if len(stocks) == 0:
        messagebox.showerror("Error", "Add at least one stock")
        return

    budget = int(entry_budget.get())

    dp_result = knapsack(stocks, budget)
    greedy_result = fractional(stocks, budget)

    result_label.config(
        text=f"0/1 Knapsack Profit: {dp_result}\nFractional Profit: {round(greedy_result,2)}"
    )

root = tk.Tk()
root.title("Stock Profit Maximizer")
root.geometry("400x500")

tk.Label(root, text="Stock Name").pack()
entry_name = tk.Entry(root)
entry_name.pack()

tk.Label(root, text="Price").pack()
entry_price = tk.Entry(root)
entry_price.pack()

tk.Label(root, text="Profit").pack()
entry_profit = tk.Entry(root)
entry_profit.pack()

tk.Button(root, text="Add Stock", command=add_stock).pack(pady=5)

listbox = tk.Listbox(root)
listbox.pack(pady=10)

tk.Label(root, text="Enter Budget").pack()
entry_budget = tk.Entry(root)
entry_budget.pack()

tk.Button(root, text="Calculate Profit", command=calculate).pack(pady=10)

result_label = tk.Label(root, text="", fg="blue")
result_label.pack(pady=10)

root.mainloop()
